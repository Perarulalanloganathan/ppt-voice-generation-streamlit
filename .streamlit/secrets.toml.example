# Copy this file to .streamlit/secrets.toml and fill values.
# For Streamlit Community Cloud, paste these in the app Secrets editor.

# Required
GEMINI_API_KEY = "your_gemini_api_key"

# Optional
GEMINI_MODEL = "gemini-2.5-flash-lite"
GEMINI_INPUT_PRICE_PER_MILLION = "0.10"
GEMINI_OUTPUT_PRICE_PER_MILLION = "0.40"

# Alternative key name accepted by the app:
# GOOGLE_API_KEY = "your_gemini_api_key"

# Optional nested style supported by app:
# [env]
# CUSTOM_KEY = "value"
