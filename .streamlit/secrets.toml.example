# Copy this file to .streamlit/secrets.toml and fill values.
# For Streamlit Community Cloud, paste these in the app Secrets editor.

DRAUP_LLM_ENV = "dev"
DRAUP_LLM_USER = "nemili"
DRAUP_LLM_PROVIDER = "gemini"
DRAUP_LLM_PROCESS = "ppt_voice_generation"
DRAUP_LLM_MODEL = "gemini/gemini-2.5-flash-lite"
DRAUP_INPUT_PRICE_PER_MILLION = "0.10"
DRAUP_OUTPUT_PRICE_PER_MILLION = "0.40"

# Add whichever key your llm manager uses:
# OPENAI_API_KEY = "..."
# AZURE_OPENAI_API_KEY = "..."
# GOOGLE_API_KEY = "..."

# Optional nested style supported by app:
# [env]
# CUSTOM_KEY = "value"
